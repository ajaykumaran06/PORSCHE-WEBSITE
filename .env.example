# ═══════════════════════════════════════════════════════
# PORSCHE WEBSITE — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase ────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ── JWT (used for custom auth tokens) ───────────────────
# Use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# ── Admin registration code ─────────────────────────────
# Anyone registering with this code gets the admin role
ADMIN_SECRET_CODE=your-admin-secret-code-here
