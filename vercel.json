{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/server.js"
        },
        {
            "src": "/login",
            "dest": "backend/server.js"
        },
        {
            "src": "/admin",
            "dest": "backend/server.js"
        },
        {
            "src": "/static/(.*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*\.(js|css|png|jpg|svg|ico))$",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "backend/server.js"
        }
    ]
}